rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists(userId) {
      return exists(/databases/$(database)/documents/users/$(userId));
    }

    function targetUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && currentUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isTeacher() {
      return hasRole('teacher');
    }

    function isStudent() {
      return hasRole('student');
    }

    function isSelf(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isCreator() {
      return isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }

    function teacherSections() {
      return currentUserData().sectionsHandled;
    }

    function isStudentInTeacherScope(studentData) {
      return isTeacher() &&
             studentData.role == 'student' &&
             (
               teacherSections() == null ||
               teacherSections().size() == 0 ||
               (studentData.gradeLevel != null &&
                teacherSections().hasAny([studentData.gradeLevel])) ||
               (studentData.section != null &&
                teacherSections().hasAny([studentData.section]))
             );
    }

    function canModerateStudent(userId) {
      return isTeacher() &&
             userExists(userId) &&
             isStudentInTeacherScope(targetUserData(userId)) &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly([
               'verified',
               'verifiedAt',
               'verifiedBy',
               'rejected',
               'rejectedAt',
               'rejectionReason',
               'rejectedBy'
             ]);
    }

    function canCreateOwnUserDoc(userId) {
      return isAuthenticated() &&
             request.auth.uid == userId &&
             ['student', 'teacher'].hasAny([request.resource.data.role]);
    }

    function canCreateNotification() {
      return isAuthenticated() &&
             request.resource.data.userId is string &&
             userExists(request.resource.data.userId) &&
             request.resource.data.role is string &&
             targetUserData(request.resource.data.userId).role == request.resource.data.role &&
             request.resource.data.title is string &&
             request.resource.data.message is string &&
             request.resource.data.type is string &&
             request.resource.data.isRead == false &&
             (
               isAdmin() ||
               isTeacher() ||
               (
                 isStudent() &&
                 (
                   request.resource.data.userId == request.auth.uid ||
                   targetUserData(request.resource.data.userId).role == 'teacher'
                 )
               )
             );
    }

    function isNotificationCreator() {
      return isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() &&
                     (
                       isSelf(userId) ||
                       isAdmin() ||
                       (isTeacher() && resource.data.role == 'student')
                     );

      allow create: if isAdmin() || canCreateOwnUserDoc(userId);

      allow update: if isAuthenticated() &&
                      (
                        (
                          isSelf(userId) &&
                          !request.resource.data.diff(resource.data).affectedKeys().hasAny([
                            'role',
                            'verified',
                            'verifiedAt',
                            'verifiedBy',
                            'rejected',
                            'rejectedAt',
                            'rejectionReason',
                            'rejectedBy',
                            'deleted',
                            'deletedAt',
                            'deletedBy'
                          ])
                        ) ||
                        canModerateStudent(userId) ||
                        isAdmin()
                      );

      allow delete: if isAdmin();
    }

    match /lessons/{lessonId} {
      allow read: if isAuthenticated() &&
                     (resource.data.isPublished == true || isCreator() || isAdmin());

      allow create: if (isTeacher() || isAdmin()) &&
                      request.resource.data.createdBy == request.auth.uid;

      allow update: if isAuthenticated() && (isCreator() || isAdmin());

      allow delete: if isAuthenticated() && (isCreator() || isAdmin());
    }

    match /quizzes/{quizId} {
      allow read: if isAuthenticated() &&
                     (resource.data.isPublished == true || isCreator() || isAdmin());

      allow create: if (isTeacher() || isAdmin()) &&
                      request.resource.data.createdBy == request.auth.uid;

      allow update: if isAuthenticated() && (isCreator() || isAdmin());

      allow delete: if isAuthenticated() && (isCreator() || isAdmin());
    }

    match /quiz_results/{resultId} {
      allow read: if isAuthenticated() &&
                     (
                       resource.data.studentId == request.auth.uid ||
                       isTeacher() ||
                       isAdmin()
                     );

      allow create: if isStudent() &&
                      request.resource.data.studentId == request.auth.uid;

      allow update: if isAuthenticated() &&
                      resource.data.studentId == request.auth.uid;

      allow delete: if isAdmin();
    }

    match /lesson_progress/{progressId} {
      allow read: if isAuthenticated() &&
                     (
                       resource.data.userId == request.auth.uid ||
                       isTeacher() ||
                       isAdmin()
                     );

      allow create: if isStudent() &&
                      request.resource.data.userId == request.auth.uid;

      allow update: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid;

      allow delete: if isAdmin();
    }

    match /lesson_notes/{noteId} {
      allow read: if isAuthenticated() &&
                     (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if isStudent() &&
                      request.resource.data.userId == request.auth.uid;

      allow update: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid;

      allow delete: if isAuthenticated() &&
                      (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /bookmarks/{bookmarkId} {
      allow read: if isAuthenticated() &&
                     (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if isStudent() &&
                      request.resource.data.userId == request.auth.uid;

      allow update: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid;

      allow delete: if isAuthenticated() &&
                      (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
                     (
                       resource.data.userId == request.auth.uid ||
                       isNotificationCreator() ||
                       isAdmin()
                     );

      allow create: if canCreateNotification();

      allow update: if isAuthenticated() &&
                      (
                        resource.data.userId == request.auth.uid ||
                        isAdmin()
                      );

      allow delete: if isAuthenticated() &&
                      (
                        resource.data.userId == request.auth.uid ||
                        isNotificationCreator() ||
                        isAdmin()
                      );
    }

    match /teacher_announcements/{announcementId} {
      allow read: if isAuthenticated() &&
                     (isAdmin() || resource.data.createdBy == request.auth.uid);

      allow create: if isTeacher() &&
                      request.resource.data.createdBy == request.auth.uid;

      allow update: if isAuthenticated() &&
                      (resource.data.createdBy == request.auth.uid || isAdmin());

      allow delete: if isAuthenticated() &&
                      (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    match /announcements/{announcementId} {
      allow read: if isAuthenticated() &&
                     (isAdmin() || resource.data.createdBy == request.auth.uid);

      allow create: if isAdmin();

      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    match /subjects/{subjectId} {
      allow read: if isAuthenticated();

      allow create: if isAdmin();

      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    match /app_config/{configId} {
      allow read: if isAuthenticated();

      allow create: if isAdmin();

      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    match /rejection_logs/{logId} {
      allow read: if isAdmin();

      allow create: if isTeacher() || isAdmin();

      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    match /deletion_logs/{logId} {
      allow read: if isAdmin();

      allow create: if isAdmin();

      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    match /ai_usage_logs/{logId} {
      allow read: if isAuthenticated() &&
                     (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if (isTeacher() || isAdmin()) &&
                      request.resource.data.userId == request.auth.uid;

      allow update: if isAdmin();

      allow delete: if isAdmin();
    }
  }
}
